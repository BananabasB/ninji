<?xml version="1.0" encoding="utf-8"?>
<!--
This is a sample appcast.xml file for Sparkle updates.
You need to host this on your server and update the feedURL in UpdaterController.swift

To generate a proper Ed25519 signature and create signed updates, run:

1. Generate signing key:
  作者: ed25519_sk.pk8

2. Sign your app archive:
   xcrun altool --sign-app-file Ninji.app --key ed25519_sk.pk8 --ed25519

3. Use sparkle-autoupdate to generate the appcast:
   https://github.com/sparkle-project/sparkle-autoupdate

Replace the URL in UpdaterController.swift with your hosted appcast.xml URL.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
    <channel>
        <title>Ninji</title>
        <description>Nintendo Music desktop wrapper</description>
        <language>en</language>
        <item>
            <title>Version 1.0.1</title>
            <pubDate>Mon, 08 Jun 2026 00:00:00 +0000</pubDate>
            <sparkle:version>1.0.1</sparkle:version>
            <sparkle:shortVersionString>1.0.1</sparkle:shortVersionString>
            <sparkle:deltaFrom>1.0.0</sparkle:deltaFrom>
            <description>
                <![CDATA[
                    <h1>Ninji 1.0.1</h1>
                    <p>Initial release with Sparkle update support.</p>
                    <ul>
                        <li>Fixed initial loading issues</li>
                        <li>Added automatic updates via Sparkle</li>
                    </ul>
                ]]>
            </description>
            <enclosure 
                url="https://your-server.com/ninji/Ninji-1.0.1.zip" 
                length="12345678" 
                type="application/octet-stream" 
                sparkle:editable="true"/>
            <sparkle:signature>
                <!-- ED25519 signature of the update archive -->
                MEUCIQC...
            </sparkle:signature>
        </item>
    </channel>
</rss>
